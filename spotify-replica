<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Spotify Web Clone</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<style>
body{
    background:#121212;
    color:white;
    overflow:hidden;
    font-family: Arial, Helvetica, sans-serif;
}

/* SIDEBAR */
.sidebar{
    background:#000;
    height:100vh;
    padding:20px;
    position:fixed;
    width:240px;
}

.sidebar h4{
    color:#1DB954;
    font-weight:bold;
}

.sidebar a{
    color:#b3b3b3;
    text-decoration:none;
    display:block;
    margin:15px 0;
    font-weight:500;
}

.sidebar a:hover{
    color:white;
}

.playlist-scroll{
    margin-top:20px;
    max-height:300px;
    overflow-y:auto;
}

/* MAIN CONTENT */
.main{
    margin-left:240px;
    height:calc(100vh - 90px);
    overflow-y:auto;
    padding:25px;
}

.topbar{
    position:sticky;
    top:0;
    background:#121212;
    padding-bottom:15px;
    z-index:10;
}

.search-box{
    background:#242424;
    border:none;
    border-radius:20px;
    padding:8px 15px;
    color:white;
    width:300px;
}

.section-title{
    font-size:24px;
    font-weight:bold;
    margin-top:30px;
}

.card-music{
    background:#181818;
    padding:15px;
    border-radius:10px;
    transition:0.3s;
    position:relative;
    cursor:pointer;
}

.card-music:hover{
    background:#282828;
}

.card-music img{
    width:100%;
    border-radius:8px;
}

.play-btn{
    position:absolute;
    bottom:20px;
    right:20px;
    background:#1DB954;
    width:45px;
    height:45px;
    border-radius:50%;
    display:flex;
    align-items:center;
    justify-content:center;
    opacity:0;
    transition:0.3s;
}

.card-music:hover .play-btn{
    opacity:1;
    transform:translateY(-5px);
}

/* PLAYER */
.player{
    position:fixed;
    bottom:0;
    width:100%;
    height:90px;
    background:#181818;
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding:0 20px;
}

.player-left img{
    width:60px;
    border-radius:5px;
}

.player-controls i{
    font-size:22px;
    margin:0 15px;
    cursor:pointer;
}

.progress-container{
    width:500px;
}

.progress{
    height:4px;
    background:#535353;
}

.progress-bar{
    background:#1DB954;
}
</style>
</head>
<body>

<!-- SIDEBAR -->
<div class="sidebar">
<h4>Spotify</h4>

<a href="#"><i class="bi bi-house-fill"></i> Home</a>
<a href="#"><i class="bi bi-search"></i> Search</a>
<a href="#"><i class="bi bi-collection"></i> Your Library</a>

<hr>

<strong>Your Playlists</strong>
<div class="playlist-scroll">
<a href="#">Liked Songs</a>
<a href="#">Top Hits 2025</a>
<a href="#">Chill Vibes</a>
<a href="#">Workout Mix</a>
<a href="#">Daily Mix 1</a>
<a href="#">Daily Mix 2</a>
<a href="#">Focus Flow</a>
<a href="#">Coding Mode</a>
</div>
</div>

<!-- MAIN -->
<div class="main">

<div class="topbar d-flex justify-content-between align-items-center">
<input type="text" id="searchInput" class="search-box" placeholder="Search songs..." onkeyup="searchSongs()">
</div>

<div class="section-title">Recently Played</div>
<div class="row g-4" id="recentContainer"></div>

<div class="section-title">Made For You</div>
<div class="row g-4" id="madeContainer"></div>

</div>

<!-- PLAYER -->
<div class="player">
<div class="player-left d-flex align-items-center gap-3">
<img id="playerImg" src="">
<div>
<div id="playerTitle">No song selected</div>
<small id="playerArtist"></small>
</div>
</div>

<div class="player-controls text-center">
<i class="bi bi-skip-backward-fill" onclick="prevSong()"></i>
<i class="bi bi-play-circle-fill" id="playBtn" onclick="playPause()"></i>
<i class="bi bi-skip-forward-fill" onclick="nextSong()"></i>
<div class="progress-container mt-2">
<div class="progress">
<div class="progress-bar" id="progressBar" style="width:0%"></div>
</div>
</div>
</div>

<div>
<i class="bi bi-volume-up"></i>
</div>

<audio id="audioPlayer"></audio>
</div>

<script>

let songs=[
{title:"Husn",artist:"Anuv Jain",img:"https://picsum.photos/300?1",src:"https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3"},
{title:"We Don't Talk Anymore",artist:"Charlie Puth",img:"https://picsum.photos/300?2",src:"https://www.soundhelix.com/examples/mp3/SoundHelix-Song-2.mp3"},
{title:"Shakira - Hips Don't Lie",artist:"Shakira",img:"https://picsum.photos/300?3",src:"https://www.soundhelix.com/examples/mp3/SoundHelix-Song-3.mp3"},
{title:"Ram Siya Ram",artist:"Sachet Tandon",img:"https://picsum.photos/300?4",src:"https://www.soundhelix.com/examples/mp3/SoundHelix-Song-4.mp3"},
{title:"Kesariya",artist:"Arijit Singh",img:"https://picsum.photos/300?5",src:"https://www.soundhelix.com/examples/mp3/SoundHelix-Song-5.mp3"}
];

let currentIndex=0;
let audio=document.getElementById("audioPlayer");

function renderSection(container,data){
let html="";
data.forEach((song,index)=>{
html+=`
<div class="col-md-2">
<div class="card-music" onclick="playSong(${index})">
<img src="${song.img}">
<h6 class="mt-2">${song.title}</h6>
<small>${song.artist}</small>
<div class="play-btn"><i class="bi bi-play-fill text-black"></i></div>
</div>
</div>
`;
});
document.getElementById(container).innerHTML=html;
}

function playSong(index){
currentIndex=index;
audio.src=songs[index].src;
audio.play();

playerImg.src=songs[index].img;
playerTitle.innerText=songs[index].title;
playerArtist.innerText=songs[index].artist;

playBtn.className="bi bi-pause-circle-fill";
}

function playPause(){
if(audio.paused){
audio.play();
playBtn.className="bi bi-pause-circle-fill";
}else{
audio.pause();
playBtn.className="bi bi-play-circle-fill";
}
}

function nextSong(){
currentIndex=(currentIndex+1)%songs.length;
playSong(currentIndex);
}

function prevSong(){
currentIndex=(currentIndex-1+songs.length)%songs.length;
playSong(currentIndex);
}

audio.addEventListener("timeupdate",()=>{
let percent=(audio.currentTime/audio.duration)*100;
progressBar.style.width=percent+"%";
});

function searchSongs(){
let query=searchInput.value.toLowerCase();
let filtered=songs.filter(s=>s.title.toLowerCase().includes(query));
renderSection("recentContainer",filtered);
}

renderSection("recentContainer",songs);
renderSection("madeContainer",songs);

</script>

</body>
</html>
